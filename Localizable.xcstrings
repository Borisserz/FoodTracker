        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Su protocolo requiere recalibración. Concéntrese en alcanzar sus objetivos diarios de manera más consistente. Empiece por priorizar las proteínas y beber al menos 2 litros de agua."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre protocole nécessite un recalibrage. Concentrez-vous sur l’atteinte de vos objectifs quotidiens de manière plus cohérente. Commencez par privilégier les protéines et buvez au moins 2 litres d’eau."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il protocollo richiede una ricalibrazione. Concentrati sul raggiungimento dei tuoi obiettivi giornalieri in modo più coerente. Inizia dando priorità alle proteine ​​e bevendo almeno 2 litri di acqua."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seu protocolo requer recalibração. Concentre-se em atingir suas metas diárias de forma mais consistente. Comece priorizando proteínas e bebendo pelo menos 2 litros de água."
          }
        },
        "ru" : {
          "stringUnit" : {
