    "Pearly white halibut cooked gently submerged in premium olive oil, resting in a fragrant golden broth with crunchy, salty sea beans. 🐟" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Perlweißer Heilbutt, sanft gegart, eingetaucht in erstklassiges Olivenöl, ruht in einer duftenden goldenen Brühe mit knusprigen, salzigen Meeresbohnen. 🐟"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fletán blanco nacarado cocinado suavemente sumergido en aceite de oliva de primera calidad, reposando en un fragante caldo dorado con crujientes y saladas alubias. 🐟"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Flétan blanc nacré cuit doucement immergé dans de l'huile d'olive de première qualité, reposant dans un bouillon doré parfumé avec des haricots de mer croquants et salés. 🐟"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ippoglosso bianco perlato cotto delicatamente immerso in olio d'oliva di prima qualità, riposato in un profumato brodo dorato con fagioli di mare croccanti e salati. 🐟"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Halibute branco perolado cozido suavemente submerso em azeite premium, descansando em um caldo dourado perfumado com grãos do mar crocantes e salgados. 🐟"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Жемчужно-белый палтус, аккуратно приготовленный в оливковом масле премиум-класса, в ароматном золотистом бульоне с хрустящими солеными морскими бобами. 🐟"
