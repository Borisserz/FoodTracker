    "Distribute your protein intake in 30-40g portions every 3-4 hours to keep muscle protein synthesis optimized." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verteilen Sie Ihre Proteinzufuhr alle 3–4 Stunden in Portionen von 30–40 g, um die Muskelproteinsynthese zu optimieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Distribute your protein intake in 30-40g portions every 3-4 hours to keep muscle protein synthesis optimized."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Distribuya su ingesta de proteínas en porciones de 30-40 g cada 3-4 horas para mantener optimizada la síntesis de proteínas musculares."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Répartissez votre apport en protéines par portions de 30 à 40 g toutes les 3 à 4 heures pour optimiser la synthèse des protéines musculaires."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Distribuisci l'apporto proteico in porzioni da 30-40 g ogni 3-4 ore per mantenere ottimizzata la sintesi proteica muscolare."
