    "Wake up to a ready-to-eat, creamy and nutritious chia pudding topped with fresh fruit. 🥄🍓" : {
      "extractionState" : "manual",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Despiértese con un pudín de chía nutritivo, cremoso y listo para comer, cubierto con fruta fresca. 🥄🍓"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Réveillez-vous avec un pudding au chia prêt à manger, crémeux et nutritif, garni de fruits frais. 🥄🍓"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Svegliati con un budino di chia pronto da mangiare, cremoso e nutriente, condito con frutta fresca. 🥄🍓"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acorde com um pudim de chia pronto para comer, cremoso e nutritivo, coberto com frutas frescas. 🥄🍓"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Просыпайтесь с готовым к употреблению сливочным и питательным пудингом из чиа, украшенным свежими фруктами. 🥄🍓"
          }
        }
      }
    },
