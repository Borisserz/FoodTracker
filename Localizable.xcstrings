    "Finish eating at least 3 hours before sleep. This lowers insulin levels and improves deep sleep recovery phases." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Essen Sie mindestens 3 Stunden vor dem Schlafengehen zu Ende. Dies senkt den Insulinspiegel und verbessert die Erholungsphasen im Tiefschlaf."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finish eating at least 3 hours before sleep. This lowers insulin levels and improves deep sleep recovery phases."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Termina de comer al menos 3 horas antes de dormir. Esto reduce los niveles de insulina y mejora las fases de recuperación del sueño profundo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finissez de manger au moins 3 heures avant de dormir. Cela réduit les niveaux d’insuline et améliore les phases de récupération du sommeil profond."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finisci di mangiare almeno 3 ore prima di andare a dormire. Ciò abbassa i livelli di insulina e migliora le fasi di recupero del sonno profondo."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Termine de comer pelo menos 3 horas antes de dormir. Isso reduz os níveis de insulina e melhora as fases de recuperação do sono profundo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Заканчивайте есть минимум за 3 часа до сна. Это снижает уровень инсулина и улучшает фазы глубокого сна."
          }
        }
      }
    },
