        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нежный, сочный и наполненный вкусом. Эти стейки — идеальный ужин с высоким содержанием белка. 🥩🧄"
          }
        }
      }
    },
