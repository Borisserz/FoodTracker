    "On your 500 kcal days, focus entirely on lean protein and leafy greens to stay full.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Konzentrieren Sie sich an Ihren 500-kcal-Tagen ausschließlich auf mageres Eiweiß und Blattgemüse, um satt zu bleiben."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En tus días de 500 kcal, concéntrate exclusivamente en proteínas magras y verduras de hojas verdes para mantenerte lleno."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lors de vos journées de 500 kcal, concentrez-vous entièrement sur les protéines maigres et les légumes-feuilles pour rester rassasié."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nei tuoi giorni da 500 kcal, concentrati interamente sulle proteine ​​magre e sulle verdure a foglia verde per rimanere sazio."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Nos seus dias de 500 kcal, concentre-se inteiramente em proteínas magras e folhas verdes para se manter saciado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В дни, когда вы потребляете 500 ккал, полностью сосредоточьтесь на нежирном белке и листовой зелени, чтобы оставаться сытыми."
          }
        }
      }
    },
    "One day on, one day off. Breaks plateaus.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Tag an, ein Tag frei. Durchbricht Plateaus."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un día encendido, un día libre. Rompe mesetas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un jour de travail, un jour de congé. Casse les plateaux."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un giorno sì, un giorno libero. Rompe gli altipiani."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Um dia de folga, um dia de folga. Quebra platôs."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Один рабочий день, один выходной. Разбивает плато."
          }
        }
      }
    },
    "One Meal A Day. Extreme fat burn and repair.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine Mahlzeit am Tag. Extreme Fettverbrennung und Reparatur."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una comida al día. Quema y reparación extrema de grasas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un repas par jour. Brûlure et réparation extrêmes des graisses."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un pasto al giorno. Brucia e ripara i grassi estremi."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma refeição por dia. Queima e reparação extrema de gordura."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Один прием пищи в день. Экстремальное сжигание и восстановление жира."
          }
        }
      }
    },
