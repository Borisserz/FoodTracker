    "If every day was exactly like today." : {
      "comment" : "A description under the projected weight change, explaining that the weight change is projected based on the user's current calorie deficit or surplus.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn jeder Tag genau wie heute wäre."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si todos los días fueran exactamente como hoy."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si chaque jour était exactement comme aujourd'hui."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se ogni giorno fosse esattamente come oggi."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se todos os dias fossem exatamente como hoje."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если бы каждый день был таким."
          }
        }
      }
    },
    "If the app is closed, your plan generation will be interrupted. Keep the app open for best results." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn die App geschlossen ist, wird Ihre Planerstellung unterbrochen. Halten Sie die App geöffnet, um optimale Ergebnisse zu erzielen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si se cierra la aplicación, se interrumpirá la generación de su plan. Mantenga la aplicación abierta para obtener mejores resultados."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si l'application est fermée, la génération de votre plan sera interrompue. Gardez l'application ouverte pour de meilleurs résultats."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se l'app viene chiusa, la generazione del piano verrà interrotta. Tieni l'app aperta per ottenere i migliori risultati."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Caso o aplicativo seja fechado, a geração do seu plano será interrompida. Mantenha o aplicativo aberto para obter melhores resultados."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если приложение закрыто, создание вашего плана будет прервано. Держите приложение открытым для достижения наилучших результатов."
          }
        }
      }
    },
    "If you continue as a guest, your nutrition, calories, and water balance data will not be saved in the cloud. You will lose your diary if you change devices." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Sie als Gast fortfahren, werden Ihre Nährwert-, Kalorien- und Wasserhaushaltsdaten nicht in der Cloud gespeichert. Wenn Sie das Gerät wechseln, geht Ihr Tagebuch verloren."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si continúas como invitado, tus datos de nutrición, calorías y balance hídrico no se guardarán en la nube. Perderás tu diario si cambias de dispositivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vous continuez en tant qu'invité, vos données nutritionnelles, caloriques et hydriques ne seront pas enregistrées dans le cloud. Vous perdrez votre agenda si vous changez d'appareil."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se continui come ospite, i dati relativi a nutrizione, calorie e bilancio idrico non verranno salvati nel cloud. Perderai il tuo diario se cambi dispositivo."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se você continuar como convidado, seus dados de nutrição, calorias e equilíbrio hídrico não serão salvos na nuvem. Você perderá seu diário se mudar de dispositivo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если вы продолжите работу в качестве гостя, данные о вашем питании, калориях и водном балансе не будут сохранены в облаке. Вы потеряете свой дневник, если смените устройство."
          }
        }
      }
    },
