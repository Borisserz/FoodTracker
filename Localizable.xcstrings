    "Incredibly tender, milk-fed veal cooked precisely sous-vide, glazed with a deeply fermented, umami-bomb black garlic reduction. 🥩" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unglaublich zartes, mit Milch gefüttertes Kalbfleisch, präzise Sous-Vide gegart, glasiert mit einer tief fermentierten Umami-Bomben-Reduktion aus schwarzem Knoblauch. 🥩"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ternera increíblemente tierna, alimentada con leche, cocinada precisamente al vacío, glaseada con una reducción de ajo negro con forma de bomba umami, profundamente fermentada. 🥩"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Veau de lait incroyablement tendre, cuit avec précision sous vide, glacé avec une réduction d'ail noir profondément fermentée et bombe umami. 🥩"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vitello incredibilmente tenero, nutrito con latte, cotto con precisione sottovuoto, glassato con una riduzione di aglio nero profondamente fermentata e bomba umami. 🥩"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vitela incrivelmente macia, alimentada com leite, cozida precisamente sous-vide, glaceada com uma redução de alho preto profundamente fermentada e com bomba umami. 🥩"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Невероятно нежная телятина на молочном откорме, приготовленная в режиме су-вид и глазированная глубоко ферментированным, бомбическим соусом из черного чеснока. 🥩"
          }
        }
      }
    },
