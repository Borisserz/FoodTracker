    "FoodTracker AI provides general nutritional information. It is not a substitute for professional medical advice, diagnosis, or treatment.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "FoodTracker AI fournit des informations nutritionnelles générales. Cela ne remplace pas un avis médical professionnel, un diagnostic ou un traitement."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "FoodTracker AI liefert allgemeine Nährwertinformationen. Es ist kein Ersatz für professionelle medizinische Beratung, Diagnose oder Behandlung."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "FoodTracker AI fornisce informazioni nutrizionali generali. Non sostituisce la consulenza, la diagnosi o il trattamento medico professionale."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "FoodTracker AI fornece informações nutricionais gerais. Não substitui o aconselhamento, diagnóstico ou tratamento médico profissional."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "FoodTracker AI предоставляет общую информацию о питании. Оно не заменяет профессиональную медицинскую консультацию, диагностику или лечение."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "FoodTracker AI proporciona información nutricional general. No sustituye el asesoramiento, diagnóstico o tratamiento médico profesional."
          }
        }
      }
    },
