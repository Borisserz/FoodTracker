    "The algorithm uses this data to accurately calculate your BMR (Basal Metabolic Rate) and your daily macronutrient needs." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Algorithmus verwendet diese Daten, um Ihren BMR (Basal Metabolic Rate) und Ihren täglichen Makronährstoffbedarf genau zu berechnen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El algoritmo utiliza estos datos para calcular con precisión su BMR (tasa metabólica basal) y sus necesidades diarias de macronutrientes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'algorithme utilise ces données pour calculer avec précision votre BMR (Basal Metabolic Rate) et vos besoins quotidiens en macronutriments."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'algoritmo utilizza questi dati per calcolare con precisione il tuo BMR (tasso metabolico basale) e il tuo fabbisogno giornaliero di macronutrienti."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O algoritmo usa esses dados para calcular com precisão sua TMB (Taxa Metabólica Basal) e suas necessidades diárias de macronutrientes."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Алгоритм использует эти данные для точного расчета вашего BMR (базального уровня метаболизма) и ваших ежедневных потребностей в макронутриентах."
          }
        }
      }
    },
    "The golden standard of fasting. Perfect for fat loss." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der goldene Standard des Fastens. Perfekt zum Fettabbau."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El estándar de oro del ayuno. Perfecto para perder grasa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La norme d’or du jeûne. Parfait pour perdre de la graisse."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lo standard d'oro del digiuno. Perfetto per la perdita di grasso."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O padrão de ouro do jejum. Perfeito para perda de gordura."
          }
        },
