          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine extreme Eliminationsdiät, die ausschließlich aus Fleisch, Fisch, Eiern und etwas Milchprodukten besteht. Keine pflanzlichen Lebensmittel."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una dieta de eliminación extrema compuesta exclusivamente de carne, pescado, huevos y algunos lácteos. Cero alimentos vegetales."
