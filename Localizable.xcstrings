    "You are low on protein today. Try adding chicken, eggs, or tofu to your next meal." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You are low on protein today. Try adding chicken, eggs, or tofu to your next meal."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tienes pocas proteínas hoy. Intente agregar pollo, huevos o tofu a su próxima comida."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous manquez de protéines aujourd’hui. Try adding chicken, eggs, or tofu to your next meal."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hai poche proteine ​​oggi. Prova ad aggiungere pollo, uova o tofu al tuo prossimo pasto."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você está com pouca proteína hoje. Experimente adicionar frango, ovos ou tofu à sua próxima refeição."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сегодня вам не хватает белка. Попробуйте добавить курицу, яйца или тофу в следующий прием пищи."
          }
        }
      }
    },
    "You haven't logged any food for this day yet." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie haben für diesen Tag noch kein Essen eingetragen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aún no has registrado ninguna comida para este día."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous n'avez pas encore enregistré de nourriture pour cette journée."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Non hai ancora registrato alcun cibo per questo giorno."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você ainda não registrou nenhuma comida para este dia."
          }
        },
