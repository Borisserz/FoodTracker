        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Souhaitez-vous mettre à jour votre profil de poids à %@ kg et recalculer vos objectifs quotidiens en calories et en eau en fonction de votre nouvelle composition corporelle ?"
          }
