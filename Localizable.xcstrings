    "Recipes: Explore Healthy Cooking. 600+ dishes, custom meals, and step-by-step videos.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Recettes : Explorez la cuisine saine. Plus de 600 plats, repas personnalisés et vidéos étape par étape."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Rezepte: Entdecken Sie gesundes Kochen. Über 600 Gerichte, individuelle Mahlzeiten und Schritt-für-Schritt-Videos."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ricette: esplora la cucina sana. Oltre 600 piatti, pasti personalizzati e video passo passo."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Receitas: Explore a culinária saudável. Mais de 600 pratos, refeições personalizadas e vídeos passo a passo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Рецепты: изучите здоровую кулинарию. Более 600 блюд, индивидуальные блюда и пошаговые видео."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recetas: Explore la cocina saludable. Más de 600 platos, comidas personalizadas y vídeos paso a paso."
          }
        }
      }
    },
