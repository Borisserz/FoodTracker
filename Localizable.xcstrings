    "Tastes like dessert but is packed with muscle-building protein and healthy fats. 🍫🥜" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schmeckt wie ein Nachtisch, ist aber voller muskelaufbauender Proteine ​​und gesunder Fette. 🍫🥜"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sabe a postre, pero está repleto de proteínas para desarrollar músculos y grasas saludables. 🍫🥜"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il a le goût d'un dessert, mais il regorge de protéines qui renforcent les muscles et de graisses saines. 🍫🥜"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ha il sapore di un dessert ma è ricco di proteine ​​per la costruzione muscolare e grassi sani. 🍫🥜"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tem gosto de sobremesa, mas é repleto de proteínas para construção muscular e gorduras saudáveis. 🍫🥜"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "По вкусу напоминает десерт, но содержит много белка для наращивания мышечной массы и полезных жиров. 🍫🥜"
          }
        }
      }
    },
    "Tell me what you have, and I'll generate a recipe that perfectly fits your remaining calories." : {
      "comment" : "A description under the \"Fridge to Recipe\" section, explaining the feature.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sagen Sie mir, was Sie haben, und ich erstelle ein Rezept, das perfekt zu Ihren verbleibenden Kalorien passt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tell me what you have, and I'll generate a recipe that perfectly fits your remaining calories."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dime qué tienes y generaré una receta que se ajuste perfectamente a las calorías restantes."
