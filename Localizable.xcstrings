    "Eliminates all animal products. Excellent for environmental sustainability and can improve digestion.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Élimine tous les produits animaux. Excellent pour la durabilité environnementale et peut améliorer la digestion."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminiert alle tierischen Produkte. Hervorragend geeignet für die Umweltverträglichkeit und kann die Verdauung verbessern."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina tutti i prodotti animali. Ottimo per la sostenibilità ambientale e può migliorare la digestione."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina todos os produtos de origem animal. Excelente para a sustentabilidade ambiental e pode melhorar a digestão."
