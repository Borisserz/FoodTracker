    "Pair iron-rich foods (spinach, lentils) with Vitamin C (citrus, peppers) to increase iron absorption by up to 300%." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kombinieren Sie eisenreiche Lebensmittel (Spinat, Linsen) mit Vitamin C (Zitrusfrüchte, Paprika), um die Eisenaufnahme um bis zu 300 % zu erhöhen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pair iron-rich foods (spinach, lentils) with Vitamin C (citrus, peppers) to increase iron absorption by up to 300%."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Combine alimentos ricos en hierro (espinacas, lentejas) con vitamina C (cítricos, pimientos) para aumentar la absorción de hierro hasta en un 300%."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Associez les aliments riches en fer (épinards, lentilles) à la vitamine C (agrumes, poivrons) pour augmenter l'absorption du fer jusqu'à 300 %."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abbina cibi ricchi di ferro (spinaci, lenticchie) con vitamina C (agrumi, peperoni) per aumentare l'assorbimento del ferro fino al 300%."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Combine alimentos ricos em ferro (espinafres, lentilhas) com vitamina C (cítricos, pimentões) para aumentar a absorção de ferro em até 300%."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сочетайте продукты, богатые железом (шпинат, чечевица), с витамином С (цитрусовые, перец), чтобы увеличить усвоение железа до 300%."
          }
        }
      }
    },
