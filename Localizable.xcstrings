    "Simple to make, comforting to enjoy, and perfect for cozy evenings. 🍂" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einfach zuzubereiten, angenehm zu genießen und perfekt für gemütliche Abende. 🍂"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sencillo de hacer, reconfortante de disfrutar y perfecto para veladas acogedoras. 🍂"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Semplice da realizzare, confortante da gustare e perfetto per serate intime. 🍂"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Simples de fazer, reconfortante de saborear e perfeito para noites aconchegantes. 🍂"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Прост в изготовлении, приятен в использовании и идеально подходит для уютных вечеров. 🍂"
          }
        }
      }
    },
    "Simply snap a photo of your meal or scan a barcode. Our AI instantly calculates your calories, protein, fats, and carbs." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Machen Sie einfach ein Foto Ihrer Mahlzeit oder scannen Sie einen Barcode. Unsere KI berechnet sofort Ihre Kalorien, Proteine, Fette und Kohlenhydrate."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Simplemente tome una foto de su comida o escanee un código de barras. Nuestra IA calcula instantáneamente sus calorías, proteínas, grasas y carbohidratos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prenez simplement une photo de votre repas ou scannez un code-barres. Notre IA calcule instantanément vos calories, protéines, graisses et glucides."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Basta scattare una foto del tuo pasto o scansionare un codice a barre. La nostra intelligenza artificiale calcola istantaneamente calorie, proteine, grassi e carboidrati."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Basta tirar uma foto da sua refeição ou digitalizar um código de barras. Nossa IA calcula instantaneamente suas calorias, proteínas, gorduras e carboidratos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Просто сфотографируйте еду или отсканируйте штрих-код. Наш искусственный интеллект мгновенно подсчитывает ваши калории, белки, жиры и углеводы."
          }
        }
      }
    },
