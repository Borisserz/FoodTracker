    "Forces your body to burn fat for fuel instead of carbohydrates. Effective for rapid fat loss but requires strict adherence.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Force votre corps à brûler les graisses comme carburant plutôt que comme glucides. Efficace pour une perte de graisse rapide mais nécessite une adhésion stricte."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zwingt Ihren Körper dazu, Fett anstelle von Kohlenhydraten als Brennstoff zu verbrennen. Wirksam für einen schnellen Fettabbau, erfordert jedoch eine strikte Einhaltung."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Costringe il corpo a bruciare i grassi come combustibile anziché i carboidrati. Efficace per una rapida perdita di grasso ma richiede una stretta aderenza."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Força seu corpo a queimar gordura como combustível em vez de carboidratos. Eficaz para perda rápida de gordura, mas requer adesão estrita."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Заставляет ваше тело сжигать жир в качестве топлива вместо углеводов. Эффективен для быстрой потери жира, но требует строгого соблюдения."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Obliga a su cuerpo a quemar grasas como combustible en lugar de carbohidratos. Eficaz para la pérdida rápida de grasa, pero requiere un cumplimiento estricto."
          }
        }
      }
    },
