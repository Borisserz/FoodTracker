    "Gamey, incredibly lean venison roasted to a perfect rare, balanced with an intensely reduced dark berry and juniper jus. 🌲" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wildes, unglaublich mageres Wildbret, perfekt gebraten, ausgewogen mit einem intensiv reduzierten Jus aus dunklen Beeren und Wacholder. 🌲"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carne de venado jugosa e increíblemente magra asada a un punto perfecto, equilibrada con un jugo de bayas oscuras y enebro intensamente reducido. 🌲"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un gibier incroyablement maigre rôti à un point saignant parfait, équilibré avec un jus de baies noires et de genièvre intensément réduit. 🌲"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selvaggina, carne di cervo incredibilmente magra, arrostita alla perfezione, equilibrata con un succo di bacche scure e ginepro intensamente ridotto. 🌲"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carne de veado incrivelmente magra, assada até ficar mal passada, equilibrada com suco de frutas escuras e zimbro intensamente reduzido. 🌲"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Невероятно нежирная оленина, обжаренная до идеальной прожарки, сбалансированная с сильно сниженным содержанием темных ягод и можжевелового сока. 🌲"
          }
        }
      }
    },
