    "Frenched rack of lamb coated in a vibrant pistachio-herb crust, served over an intensely sweet and bright pea purée. 🥩" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Französisches Lammkarree umhüllt von einer kräftigen Pistazien-Kräuter-Kruste, serviert auf einem intensiv süßen und hellen Erbsenpüree. 🥩"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carré de cordero a la francesa cubierto con una vibrante costra de pistachos y hierbas, servido sobre un puré de guisantes intensamente dulce y brillante. 🥩"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carré d'agneau à la française enrobé d'une croûte vibrante de pistaches et d'herbes, servi sur une purée de pois intensément sucrée et lumineuse. 🥩"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carré di agnello alla francese ricoperto da una vivace crosta di erbe e pistacchi, servito su una purea di piselli intensamente dolce e brillante. 🥩"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Costeleta de cordeiro francesa revestida com uma crosta vibrante de pistache e ervas, servida sobre um purê de ervilha intensamente doce e brilhante. 🥩"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Каре ягненка по-французски, покрытое яркой корочкой из фисташек и трав, подается с очень сладким и ярким гороховым пюре. 🥩"
          }
        }
      }
    },
