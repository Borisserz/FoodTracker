        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desideri aggiornare il peso del tuo profilo a %@ kg e ricalcolare i tuoi obiettivi giornalieri di calorie e acqua per adattarli alla tua nuova composizione corporea?"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gostaria de atualizar o peso do seu perfil para %@ kg e recalcular suas metas diárias de calorias e água para corresponder à sua nova composição corporal?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
