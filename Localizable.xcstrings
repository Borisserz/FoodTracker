    "Deep insights into your consistency and habits, featuring an AI Hydration Coach that optimizes your water and pH balance." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tiefer Einblick in Ihre Konsistenz und Gewohnheiten, mit einem AI Hydration Coach, der Ihr Wasser- und pH-Gleichgewicht optimiert."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Información profunda sobre su consistencia y hábitos, con un entrenador de hidratación de IA que optimiza su equilibrio de agua y pH."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des informations approfondies sur votre régularité et vos habitudes, avec un coach d'hydratation IA qui optimise votre équilibre hydrique et pH."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approfondimenti sulla tua costanza e sulle tue abitudini, con un Coach di idratazione AI che ottimizza l'equilibrio dell'acqua e del pH."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Insights profundos sobre sua consistência e hábitos, apresentando um AI Hydration Coach que otimiza o equilíbrio de água e pH."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Глубокое понимание вашей последовательности и привычек с помощью AI Hydration Coach, который оптимизирует ваш водный баланс и баланс pH."
          }
        }
      }
    },
