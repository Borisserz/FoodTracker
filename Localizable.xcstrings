    "Bone broth or a light salad first. Your digestive system is asleep, wake it up gently." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zuerst Knochenbrühe oder einen leichten Salat. Ihr Verdauungssystem schläft, wecken Sie es sanft auf."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Primero caldo de huesos o una ensalada ligera. Tu sistema digestivo está dormido, despiértalo suavemente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un bouillon d'os ou une salade légère au préalable. Votre système digestif est endormi, réveillez-le en douceur."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Per prima cosa, brodo di ossa o insalata leggera. Il tuo sistema digestivo sta dormendo, sveglialo dolcemente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Caldo de osso ou uma salada leve primeiro. Seu sistema digestivo está adormecido, acorde-o suavemente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bone broth or a light salad first. Your digestive system is asleep, wake it up гently."
          }
        }
      }
    },
