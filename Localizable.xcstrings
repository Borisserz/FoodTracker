    "Feeling bloated? Increase potassium intake (avocados, bananas) to assist kidneys in flushing out excess sodium." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fühlen Sie sich aufgebläht? Erhöhen Sie die Kaliumaufnahme (Avocados, Bananen), um die Nieren dabei zu unterstützen, überschüssiges Natrium auszuspülen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Feeling bloated? Increase potassium intake (avocados, bananas) to assist kidneys in flushing out excess sodium."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Te sientes hinchado? Aumente la ingesta de potasio (aguacates, plátanos) para ayudar a los riñones a eliminar el exceso de sodio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous vous sentez ballonné ? Augmentez l'apport en potassium (avocats, bananes) pour aider les reins à éliminer l'excès de sodium."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ti senti gonfio? Aumentare l’assunzione di potassio (avocado, banane) per aiutare i reni a eliminare il sodio in eccesso."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sentindo-se inchado? Aumente a ingestão de potássio (abacates, bananas) para ajudar os rins a eliminar o excesso de sódio."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Чувствуете вздутие? Увеличьте потребление калия (авокадо, бананы), чтобы помочь почкам вывести избыток натрия."
          }
        }
      }
    },
    "Feeling good? A balanced plate will keep your mood stable. Stay hydrated and stick to your plan." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fühlen Sie sich gut? Ein ausgewogener Teller hält Ihre Stimmung stabil. Bleiben Sie ausreichend hydriert und halten Sie sich an Ihren Plan."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Feeling good? A balanced plate will keep your mood stable. Stay hydrated and stick to your plan."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Te sientes bien? Un plato equilibrado mantendrá estable tu estado de ánimo. Mantente hidratado y sigue tu plan."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous vous sentez bien ? Une assiette équilibrée maintiendra votre humeur stable. Restez hydraté et respectez votre plan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ti senti bene? Un piatto equilibrato manterrà stabile il tuo umore. Rimani idratato e attieniti al tuo piano."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Está se sentindo bem? Um prato equilibrado manterá seu humor estável. Mantenha-se hidratado e siga seu plano."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Чувствуете себя хорошо? Сбалансированная тарелка сохранит ваше настроение стабильным. Пейте воду и придерживайтесь плана."
          }
        }
      }
    },
