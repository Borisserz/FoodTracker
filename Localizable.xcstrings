        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inspirado nos hábitos alimentares tradicionais da Itália e da Grécia. Ótimo para a saúde cardiovascular."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вдохновлен традиционными гастрономическими привычками Италии и Греции. Отлично подходит для здоровья сердечно-сосудистой системы."
