    "Start with a small portion of easily digestible food, wait 30 mins, then eat a full meal.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beginnen Sie mit einer kleinen Portion leicht verdaulicher Nahrung, warten Sie 30 Minuten und essen Sie dann eine vollständige Mahlzeit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comience con una pequeña porción de alimento de fácil digestión, espere 30 minutos y luego coma una comida completa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Commencez par une petite portion d’aliments faciles à digérer, attendez 30 minutes, puis prenez un repas complet."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inizia con una piccola porzione di cibo facilmente digeribile, attendi 30 minuti, quindi mangia un pasto completo."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Comece com uma pequena porção de comida de fácil digestão, espere 30 minutos e depois faça uma refeição completa."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Начните с небольшой порции легкоусвояемой пищи, подождите 30 минут, затем съешьте полноценный обед."
