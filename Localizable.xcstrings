    "Your protocol requires recalibration. Focus on hitting your daily targets more consistently. Start by prioritizing protein and drinking at least 2 liters of water." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihr Protokoll erfordert eine Neukalibrierung. Konzentrieren Sie sich darauf, Ihre täglichen Ziele konsequenter zu erreichen. Beginnen Sie damit, Proteinen den Vorrang zu geben und mindestens 2 Liter Wasser zu trinken."
          }
        },
        "en" : {
