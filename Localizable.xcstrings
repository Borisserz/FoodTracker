    "Your body is a reflection of your nutrition.\nTake control of your diet and achieve your dreams.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihr Körper ist ein Spiegelbild Ihrer Ernährung.\nÜbernehmen Sie die Kontrolle über Ihre Ernährung und verwirklichen Sie Ihre Träume."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu cuerpo es un reflejo de tu nutrición.\nToma el control de tu alimentación y consigue tus sueños."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre corps est le reflet de votre alimentation.\nPrenez le contrôle de votre alimentation et réalisez vos rêves."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo corpo è un riflesso della tua alimentazione.\nPrendi il controllo della tua dieta e realizza i tuoi sogni."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu corpo é um reflexo de sua nutrição.\nAssuma o controle de sua dieta e realize seus sonhos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваше тело является отражением вашего питания.\nВозьмите под контроль свою диету и осуществите свою мечту."
          }
        }
      }
    },
