    "Updating these metrics will automatically recalculate your recommended daily calorie goal." : {
      "comment" : "A footer text in the \"Edit Profile\" sheet that explains the impact of changing body metrics on the user's daily calorie goal.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durch die Aktualisierung dieser Messwerte wird Ihr empfohlenes tägliches Kalorienziel automatisch neu berechnet."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La actualización de estas métricas volverá a calcular automáticamente su objetivo calórico diario recomendado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La mise à jour de ces mesures recalculera automatiquement votre objectif calorique quotidien recommandé."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'aggiornamento di queste metriche ricalcolerà automaticamente l'obiettivo calorico giornaliero consigliato."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A atualização dessas métricas recalculará automaticamente sua meta diária recomendada de calorias."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Updating these metrics will automatically recalculate your recommended daily calorie цель."
          }
        }
      }
    },
    "Upload Before & After photos to visually compare your transformation and let AI analyze your physical progress." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Laden Sie Vorher- und Nachher-Fotos hoch, um Ihre Transformation visuell zu vergleichen und die KI Ihren körperlichen Fortschritt analysieren zu lassen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sube fotos de Antes y Después para comparar visualmente tu transformación y deja que la IA analice tu progreso físico."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Téléchargez des photos avant et après pour comparer visuellement votre transformation et laissez l'IA analyser vos progrès physiques."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carica foto prima e dopo per confrontare visivamente la tua trasformazione e consentire all'intelligenza artificiale di analizzare i tuoi progressi fisici."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carregue fotos de antes e depois para comparar visualmente sua transformação e deixe a IA analisar seu progresso físico."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Загрузите фотографии «До» и «После», чтобы визуально сравнить свою трансформацию, а искусственный интеллект проанализирует ваш физический прогресс."
          }
        }
      }
    },
