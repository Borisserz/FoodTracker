    "Ultra-lean red meat from premium ostrich fillet, complemented by a sweet-and-sour berry reduction and earthy, wood-smoked parsnips. 🍖" : {
      "extractionState" : "manual",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carne roja ultramagra de filete de avestruz de primera calidad, complementada con una reducción de frutos rojos agridulce y chirivías terrosas ahumadas en madera. 🍖"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Viande rouge ultra maigre issue d'un filet d'autruche de première qualité, complétée par une réduction de baies aigre-douce et des panais terreux fumés au bois. 🍖"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carne rossa ultra magra di filetto di struzzo di prima qualità, completata da una riduzione di frutti di bosco in agrodolce e pastinaca terrosa affumicata a legna. 🍖"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carne vermelha ultramagra de filé de avestruz premium, complementada por uma redução agridoce de frutas vermelhas e pastinacas terrosas defumadas a lenha. 🍖"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ультра-нежирное красное мясо из премиального филе страуса, дополненное кисло-сладким ягодным соусом и земляным пастернаком, копченным на дровах. 🍖"
          }
        }
      }
    },
    "Ultra-premium Ora King salmon slowly basted in cultured butter, resting on a silky Jerusalem artichoke velouté, crowned with a quenelle of black caviar. 🐟" : {
      "extractionState" : "manual",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Salmón Ora King ultra premium bañado lentamente en mantequilla cultivada, reposando sobre una sedosa velouté de alcachofa de Jerusalén, coronado con una quenelle de caviar negro. 🐟"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Saumon Ora King ultra-premium arrosé lentement de beurre de culture, reposant sur un velouté soyeux de topinambour, couronné d'une quenelle de caviar noir. 🐟"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Salmone Ora King ultra premium imbevuto lentamente di burro coltivato, adagiato su una vellutata setosa di topinambur, coronato da una quenelle di caviale nero. 🐟"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Salmão Ora King ultra-premium regado lentamente em manteiga cultivada, repousando sobre um sedoso velouté de alcachofra de Jerusalém, coroado com uma quenelle de caviar preto. 🐟"
          }
        },
        "ru" : {
