    "Wild, robust elk loin elevated by a sticky reduction of ruby port wine and piney juniper, grounded by earthy celery root. 🦌" : {
      "extractionState" : "manual",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lomo de alce salvaje y robusto, elevado por una reducción pegajosa de vino de Oporto rubí y enebro de pino, molido con raíz de apio terroso. 🦌"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Longe d'élan sauvage et robuste rehaussée par une réduction collante de porto rubis et de genévrier de pin, ancrée dans du céleri-rave terreux. 🦌"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lombo di alce selvatico e robusto esaltato da una riduzione appiccicosa di vino di Porto rubino e ginepro di pino, macinato da radice di sedano terrosa. 🦌"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lombo de alce selvagem e robusto elevado por uma redução pegajosa de vinho do Porto rubi e zimbro de pinho, fundamentado em raiz de aipo terroso. 🦌"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дикая, крепкая лосиная корейка, подчеркнутая липкой ноткой рубинового портвейна и соснового можжевельника, с землистым корнем сельдерея. 🦌"
          }
        }
      }
    },
