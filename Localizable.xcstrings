    "Water and meals reminders adapt to your habits. Keep using the app and times will be personalized.": {
      "comment": "A description under the toggle switches in the Reminders Settings View, explaining how the times for meals and water are adjusted based on the user's habits.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les rappels d'eau et de repas s'adaptent à vos habitudes. Continuez à utiliser l'application et les horaires seront personnalisés."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wasser- und Essenserinnerungen passen sich Ihren Gewohnheiten an. Nutzen Sie die App weiterhin und die Zeiten werden personalisiert."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I promemoria di acqua e pasti si adattano alle tue abitudini. Continua ad utilizzare l'app e gli orari saranno personalizzati."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Os lembretes de água e refeições se adaptam aos seus hábitos. Continue usando o aplicativo e os horários serão personalizados."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Напоминания о воде и еде адаптируются к вашим привычкам. Продолжайте использовать приложение, и время будет персонализировано."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los recordatorios de agua y comidas se adaptan a tus hábitos. Sigue usando la aplicación y los tiempos serán personalizados."
          }
        }
      }
    },
    "Water Balance": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bilan hydrique"
          }
        },
        "de": {
          "stringUnit": {
