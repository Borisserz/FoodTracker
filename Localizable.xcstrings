    "Rich in omega-3s and healthy fats, this simple yet elegant salmon boat is perfect for a keto dinner. 🥑🐟" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieses einfache, aber elegante Lachsboot ist reich an Omega-3-Fettsäuren und gesunden Fetten und eignet sich perfekt für ein Keto-Abendessen. 🥑🐟"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rico en omega-3 y grasas saludables, este sencillo pero elegante barco de salmón es perfecto para una cena cetogénica. 🥑🐟"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Riche en oméga-3 et en graisses saines, ce bateau au saumon simple mais élégant est parfait pour un dîner céto. 🥑🐟"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ricca di omega-3 e grassi sani, questa semplice ma elegante barchetta per salmone è perfetta per una cena cheto. 🥑🐟"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rico em ômega-3 e gorduras saudáveis, este barco de salmão simples, mas elegante, é perfeito para um jantar cetônico. 🥑🐟"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Эта простая, но элегантная лодка с лососем, богатая омега-3 и полезными жирами, идеально подходит для кето-ужина. 🥑🐟"
          }
        }
      }
    },
