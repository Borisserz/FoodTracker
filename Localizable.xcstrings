          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les éléments créés ici sont enregistrés de manière permanente dans votre base de données et peuvent être utilisés dans vos journaux quotidiens."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
