    "Your metabolic score shows energy & hydration efficiency. Keep it above **90** for peak performance!" : {
      "comment" : "A description below the metabolic score that encourages maintaining a score above 90 for optimal health.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihr Stoffwechselwert zeigt die Energie- und Flüssigkeitseffizienz an. Halten Sie den Wert über **90**, um Spitzenleistungen zu erzielen!"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Su puntuación metabólica muestra la eficiencia energética y de hidratación. ¡Manténgalo por encima de **90** para obtener el máximo rendimiento!"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre score métabolique montre l’efficacité énergétique et hydrique. Maintenez-le au-dessus de **90** pour des performances optimales !"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il tuo punteggio metabolico mostra l'efficienza energetica e di idratazione. Mantienilo sopra **90** per prestazioni ottimali!"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sua pontuação metabólica mostra eficiência energética e de hidratação. Mantenha-o acima de **90** para desempenho máximo!"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваш метаболический показатель показывает эффективность энергии и гидратации. Держите значение выше **90** для достижения максимальной производительности!"
          }
        }
      }
    },
    "Your mood impacts your digestion and cravings. Tracking it helps us find patterns over time." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihre Stimmung beeinflusst Ihre Verdauung und Ihr Verlangen. Wenn wir es verfolgen, können wir im Laufe der Zeit Muster erkennen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your mood impacts your digestion and cravings. Tracking it helps us find patterns over time."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu estado de ánimo afecta tu digestión y tus antojos. Seguirlo nos ayuda a encontrar patrones a lo largo del tiempo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre humeur a un impact sur votre digestion et vos envies. Le suivre nous aide à trouver des modèles au fil du temps."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il tuo umore influisce sulla digestione e sull'appetito. Monitorarlo ci aiuta a trovare modelli nel tempo."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seu humor afeta sua digestão e desejos. Rastreá-lo nos ajuda a encontrar padrões ao longo do tempo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваше настроение влияет на пищеварение и тягу к еде. Отслеживание помогает нам находить закономерности с течением времени."
          }
        }
      }
    },
    "Your optimized macro target." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihr optimiertes Makroziel."
