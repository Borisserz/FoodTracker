        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dimmi cosa hai e genererò una ricetta che si adatta perfettamente alle tue calorie rimanenti."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
