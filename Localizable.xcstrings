    "A classic morning staple loaded with healthy fats and lean protein to keep you energized. 🥑" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein klassisches Grundnahrungsmittel für den Morgen, vollgestopft mit gesunden Fetten und magerem Protein, um Sie mit Energie zu versorgen. 🥑"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un clásico alimento básico de la mañana cargado de grasas saludables y proteínas magras para mantenerte con energía. 🥑"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un aliment de base classique du matin chargé de graisses saines et de protéines maigres pour vous garder sous tension. 🥑"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un classico alimento mattutino ricco di grassi sani e proteine ​​magre per mantenerti pieno di energia. 🥑"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um clássico alimento matinal carregado com gorduras saudáveis ​​e proteínas magras para mantê-lo energizado. 🥑"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Классический утренний продукт, богатый полезными жирами и нежирным белком, который зарядит вас энергией. 🥑"
          }
        }
      }
    },
    "A comforting, creamy coconut curry loaded with sweet potatoes and warm spices. 🍛🍠" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein wohltuendes, cremiges Kokosnuss-Curry mit Süßkartoffeln und warmen Gewürzen. 🍛🍠"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un reconfortante y cremoso curry de coco cargado de batatas y especias calientes. 🍛🍠"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un curry de noix de coco réconfortant et crémeux chargé de patates douces et d'épices chaudes. 🍛🍠"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un curry al cocco confortante e cremoso, ricco di patate dolci e spezie calde. 🍛🍠"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um reconfortante e cremoso curry de coco carregado com batata doce e temperos quentes. 🍛🍠"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Уютное сливочно-кокосовое карри со сладким картофелем и теплыми специями. 🍛🍠"
          }
        }
      }
    },
    "A creamy, low-carb twist on traditional egg salad using nutrient-dense avocado instead of excess mayo. 🥑" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine cremige, kohlenhydratarme Variante eines traditionellen Eiersalats mit nährstoffreicher Avocado anstelle von überschüssiger Mayonnaise. 🥑"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una versión cremosa y baja en carbohidratos de la tradicional ensalada de huevo que utiliza aguacate rico en nutrientes en lugar de exceso de mayonesa. 🥑"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une version crémeuse et faible en glucides de la salade aux œufs traditionnelle utilisant de l'avocat riche en nutriments au lieu d'un excès de mayonnaise. 🥑"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una versione cremosa e a basso contenuto di carboidrati della tradizionale insalata di uova, utilizzando avocado ricco di nutrienti al posto della maionese in eccesso. 🥑"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um toque cremoso e com baixo teor de carboidratos na tradicional salada de ovo usando abacate rico em nutrientes em vez de excesso de maionese. 🥑"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сливочный вариант традиционного яичного салата с низким содержанием углеводов, в котором вместо лишнего майонеза используется богатый питательными веществами авокадо. 🥑"
          }
        }
      }
    },
    "A crispy, golden, oven-baked chicken breast with zero breadcrumbs required. 🍗" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine knusprige, goldene, im Ofen gebackene Hähnchenbrust ohne Semmelbrösel. 🍗"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una pechuga de pollo crujiente, dorada y horneada sin necesidad de pan rallado. 🍗"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une poitrine de poulet croustillante et dorée cuite au four sans chapelure requise. 🍗"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un petto di pollo croccante e dorato, cotto al forno e senza pangrattato. 🍗"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um peito de frango crocante, dourado e assado no forno, sem necessidade de farinha de rosca. 🍗"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Хрустящая золотистая куриная грудка, запеченная в духовке, без панировочных сухарей. 🍗"
          }
        }
      }
    },
    "A crispy, savory snack that replaces potato chips and packs a nice punch of plant protein. 🌶️" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
