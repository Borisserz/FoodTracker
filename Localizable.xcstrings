    "Hand-cut A5 Wagyu tenderloin bound with an aerated mustard-caper emulsion, served with a raw quail egg yolk and flaxseed tuile. 🥩" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Von Hand geschnittenes A5-Wagyu-Filet, gebunden mit einer kohlensäurehaltigen Senf-Kapern-Emulsion, serviert mit rohem Wachteleigelb und Leinsamen-Tuile. 🥩"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lomo Wagyu A5 cortado a mano, atado con una emulsión de mostaza aireada y alcaparras, servido con yema de huevo de codorniz cruda y tuile de linaza. 🥩"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Filet mignon Wagyu A5 coupé à la main, lié d'une émulsion aérée moutarde-câpres, servi avec un jaune d'œuf de caille cru et une tuile aux graines de lin. 🥩"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Filetto di Wagyu A5 tagliato a mano e legato con un'emulsione aerata di senape e capperi, servito con tuorlo d'uovo di quaglia crudo e tuile di semi di lino. 🥩"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lombo Wagyu A5 cortado à mão, coberto com emulsão aerada de mostarda e alcaparras, servido com gema de ovo de codorna crua e tuile de linhaça. 🥩"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нарезанная вручную вырезка вагю А5, переплетенная с воздушной горчично-каперсовой эмульсией, подается с сырым перепелиным желтком и тюль из льняного семени. 🥩"
          }
        }
      }
    },
