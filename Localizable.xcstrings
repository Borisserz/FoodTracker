    "Break it with lean protein (chicken/fish) and veggies. Avoid heavy carbs immediately." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brechen Sie es mit magerem Eiweiß (Huhn/Fisch) und Gemüse auf. Vermeiden Sie sofort schwere Kohlenhydrate."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rómpelo con proteínas magras (pollo/pescado) y verduras. Evite los carbohidratos pesados ​​de inmediato."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cassez-le avec des protéines maigres (poulet/poisson) et des légumes. Évitez immédiatement les glucides lourds."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spezzalo con proteine ​​magre (pollo/pesce) e verdure. Evita immediatamente i carboidrati pesanti."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Divida-o com proteínas magras (frango/peixe) e vegetais. Evite carboidratos pesados ​​imediatamente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Добавьте в него нежирный белок (курица/рыба) и овощи. Немедленно избегайте тяжелых углеводов."
          }
        }
      }
    },
