    "Designed to help treat or prevent high blood pressure. Emphasizes vegetables, fruits, and low-fat dairy foods." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entwickelt zur Behandlung oder Vorbeugung von Bluthochdruck. Der Schwerpunkt liegt auf Gemüse, Obst und fettarmen Milchprodukten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diseñado para ayudar a tratar o prevenir la presión arterial alta. Hace hincapié en las verduras, frutas y productos lácteos bajos en grasa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conçu pour aider à traiter ou à prévenir l'hypertension artérielle. Met l'accent sur les légumes, les fruits et les produits laitiers faibles en gras."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Progettato per aiutare a trattare o prevenire l'ipertensione. Enfatizza verdure, frutta e latticini a basso contenuto di grassi."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Projetado para ajudar a tratar ou prevenir a hipertensão. Enfatiza vegetais, frutas e laticínios com baixo teor de gordura."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Предназначен для лечения или предотвращения высокого кровяного давления. Особое внимание уделяется овощам, фруктам и нежирным молочным продуктам."
          }
        }
      }
    },
