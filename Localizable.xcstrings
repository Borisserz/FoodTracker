        }
      }
    },
    "Focus heavily on hydration and electrolytes on your fasting days.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Konzentrieren Sie sich an Ihren Fastentagen stark auf Flüssigkeitszufuhr und Elektrolyte."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Concéntrate mucho en la hidratación y los electrolitos en tus días de ayuno."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Concentrez-vous fortement sur l’hydratation et les électrolytes pendant vos jours de jeûne."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Concentrati molto sull'idratazione e sugli elettroliti nei giorni di digiuno."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Concentre-se fortemente na hidratação e nos eletrólitos nos dias de jejum."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В дни голодания уделяйте особое внимание гидратации и электролитам."
          }
        }
      }
    },
    "Focuses on eating windows rather than specific foods. Naturally reduces calorie intake and improves insulin sensitivity.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Konzentriert sich auf das Essen von Fenstern und nicht auf bestimmte Lebensmittel. Reduziert auf natürliche Weise die Kalorienaufnahme und verbessert die Insulinsensitivität."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se centra en comer ventanas en lugar de alimentos específicos. Reduce naturalmente la ingesta de calorías y mejora la sensibilidad a la insulina."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Se concentre sur les fenêtres de repas plutôt que sur des aliments spécifiques. Réduit naturellement l'apport calorique et améliore la sensibilité à l'insuline."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Si concentra sulle finestre alimentari piuttosto che su cibi specifici. Riduce naturalmente l'apporto calorico e migliora la sensibilità all'insulina."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Concentra-se em comer janelas em vez de alimentos específicos. Reduz naturalmente a ingestão de calorias e melhora a sensibilidade à insulina."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Фокусируется на окнах питания, а не на конкретных продуктах. Естественно снижает потребление калорий и улучшает чувствительность к инсулину."
          }
        }
      }
    },
    "Focuses on whole foods like meat, fish, eggs, vegetables, and nuts. Excludes processed foods, grains, and dairy.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Schwerpunkt liegt auf Vollwertkost wie Fleisch, Fisch, Eiern, Gemüse und Nüssen. Ausgenommen sind verarbeitete Lebensmittel, Getreide und Milchprodukte."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se centra en alimentos integrales como carne, pescado, huevos, verduras y frutos secos. Excluye alimentos procesados, cereales y lácteos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Se concentre sur les aliments entiers comme la viande, le poisson, les œufs, les légumes et les noix. Exclut les aliments transformés, les céréales et les produits laitiers."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Si concentra su cibi integrali come carne, pesce, uova, verdure e noci. Sono esclusi gli alimenti trasformati, i cereali e i latticini."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Concentra-se em alimentos integrais, como carne, peixe, ovos, vegetais e nozes. Exclui alimentos processados, grãos e laticínios."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Основное внимание уделяется цельным продуктам, таким как мясо, рыба, яйца, овощи и орехи. Исключает обработанные пищевые продукты, зерновые и молочные продукты."
          }
        }
      }
    },
