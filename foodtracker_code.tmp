                    Spacer()
                    VStack(alignment: .trailing) {
                        Text("Total Weight").font(.caption).foregroundColor(.gray)
                        Text("\(Int(totalWeight)) g").font(.system(size: 20, weight: .bold, design: .rounded))
                    }
