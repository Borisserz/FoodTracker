                            .frame(height: isScrollingDown ? 350 + minY : 350)
                            .offset(y: isScrollingDown ? -minY : 0)

                            Image(systemName: "sparkles")
                                .font(.system(size: 150))
                                .foregroundColor(.white.opacity(0.15))
                                .offset(x: 150, y: -40)

                            VStack(alignment: .leading, spacing: 8) {
