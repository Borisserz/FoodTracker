                                VStack(alignment: .leading, spacing: 4) {
                                    Text(item.name).font(.system(size: 16, weight: .semibold, design: .rounded))
                                    Text("\(item.calories) kcal — \(Int(item.weight))g")
                                        .font(.caption).foregroundColor(.gray)
