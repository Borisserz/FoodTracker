    var body: some View {
        VStack(spacing: 0) {
            ZStack(alignment: .topLeading) {
                LinearGradient(
                    colors: [article.color1, article.color2],
                    startPoint: .topLeading,
                    endPoint: .bottomTrailing
                )

                Image(systemName: article.iconName)
                    .font(.system(size: 70))
